{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/longxianmian/longcode-Entropy-Shear/schemas/policy.schema.json",
  "title": "Policy",
  "description": "Entropy Shear policy: a versioned, priority-ordered ruleset with a default verdict.",
  "type": "object",
  "required": ["id", "version", "rules", "default_effect", "default_reason"],
  "additionalProperties": false,
  "properties": {
    "id":      { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/Rule" }
    },
    "default_effect": { "$ref": "#/$defs/Verdict" },
    "default_reason": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "Verdict": { "type": "string", "enum": ["Yes", "No", "Hold"] },
    "Operator": {
      "type": "string",
      "enum": ["==", "!=", ">", "<", ">=", "<=", "in", "contains"]
    },
    "Condition": {
      "type": "object",
      "required": ["field", "operator", "value"],
      "additionalProperties": false,
      "properties": {
        "field":    { "type": "string", "minLength": 1 },
        "operator": { "$ref": "#/$defs/Operator" },
        "value":    {}
      }
    },
    "Rule": {
      "type": "object",
      "required": ["id", "priority", "condition", "effect", "reason"],
      "additionalProperties": false,
      "properties": {
        "id":        { "type": "string", "minLength": 1 },
        "priority":  { "type": "integer" },
        "condition": { "$ref": "#/$defs/Condition" },
        "effect":    { "$ref": "#/$defs/Verdict" },
        "route":     { "type": "string" },
        "reason":    { "type": "string", "minLength": 1 }
      }
    }
  }
}
